{
  "name": "@agentsdk/react",
  "version": "0.1.0",
  "description": "React hooks and provider for @agentsdk/core — useAgent, AgentProvider, assistant-ui integration",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agentsdk/core": "workspace:*"
  },
  "peerDependencies": {
    "@assistant-ui/react": ">=0.12.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@assistant-ui/react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@agentsdk/core": "workspace:*",
    "@assistant-ui/react": "^0.12.17",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "react": "^19.2.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}
